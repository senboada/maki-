# Supabase local defaults for iOS Simulator.
# Run `npm run supabase:status` after `npm run supabase:start` and copy the
# current anon key if Supabase CLI generated a different one.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key-from-supabase-status

# Android Emulator usually needs the host alias instead of 127.0.0.1:
# EXPO_PUBLIC_SUPABASE_URL=http://10.0.2.2:54321
